# ── Hugging Face (needed for Pyannote model download) ────────────────
# Get free token at: https://huggingface.co/settings/tokens
# Then accept terms at: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN= your_hugging_face_api_key_here

# ── Groq API (free tier Whisper) ─────────────────────────────────────
# Get free token at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Supabase (for later indexing phase) ──────────────────────────────
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# ── Livekit (for online speech seperation) ──────────────────────────────
LIVEKIT_URL=your_livekit_url_here
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here
